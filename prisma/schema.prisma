// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String?
  createdAt    DateTime @default(now())

  tasks    Task[]
  goals    Goal[]
  habits   Habit[]
  journals JournalEntry[]
}

model Task {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  title       String
  description String?
  date        DateTime
  completed   Boolean   @default(false)
  priority    Priority  @default(MEDIUM)
  startTime   String?
  endTime     String?
  rescheduled Boolean   @default(false)
  createdAt   DateTime  @default(now())

  @@index([userId, date])
}

enum Priority {
  LOW
  MEDIUM
  HIGH
}

model Goal {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  title       String
  description String?
  type        GoalType  @default(SHORT_TERM)
  targetDate  DateTime?
  progress    Int       @default(0)
  createdAt   DateTime  @default(now())

  @@index([userId])
}

enum GoalType {
  SHORT_TERM
  LONG_TERM
}

model Habit {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  color     String   @default("#2563eb")
  createdAt DateTime @default(now())

  logs HabitLog[]

  @@index([userId])
}

model HabitLog {
  id        String   @id @default(cuid())
  habitId   String
  habit     Habit    @relation(fields: [habitId], references: [id], onDelete: Cascade)
  date      DateTime
  completed Boolean  @default(true)

  @@unique([habitId, date])
}

model JournalEntry {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  date      DateTime
  content   String
  mood      String?
  createdAt DateTime @default(now())

  @@unique([userId, date])
}
